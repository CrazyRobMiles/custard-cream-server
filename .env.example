# Copy this file to .env and fill in real values.
# .env is gitignored - never committed.

# Same Atlas connection string as box-server's .env, so both servers
# share the same "connected_little_boxes" database and User collection.
DATABASE_URL=mongodb+srv://dbUser:password@cluster0.example.mongodb.net/dbUser?retryWrites=true&w=majority

# Same value as box-server's ACTIVE_TOKEN_SECRET, so JWT handling is consistent
# across both apps (a token is only ever verified by the server that issued it,
# but keeping the secret identical avoids surprises if that ever changes).
ACTIVE_TOKEN_SECRET=

PORT=3100
HOST_ADDRESS=http://custardcream.cam/

# Optional. Leave unset for normal use - the app then reads/writes the real
# "pictures" collection. Set this to point the whole app (and scripts/*.js) at
# a different collection instead, e.g. for local test runs against data seeded
# by scripts/seedTestPictures.js that matches whatever's actually in
# public/pictures/ on this machine, without ever touching the real production
# Picture documents (most of which reference files this machine doesn't have).
PICTURES_COLLECTION=

# Bootstrap credentials for the dedicated camera account (role: "camera").
# Created automatically on first startup if it doesn't already exist.
CAMERA_ACCOUNT_EMAIL=camera@custardcreamcamera.local
CAMERA_ACCOUNT_PASSWORD=change-me

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta1/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-giJF6kkoqNQ00vy+HMDP7azOuL0xtbfIcaT9wjKHr8RbDVddVHyTfAAsrekwKmP1" crossorigin="anonymous">
    <title>Custard Cream Server - Manage Pictures</title>
    <style>
        .gallery-thumb {
            cursor: pointer;
            width: 100%;
            height: 220px;
            object-fit: cover;
        }

        .viewer-overlay {
            position: fixed;
            inset: 0;
            z-index: 1050;
            background: rgba(0, 0, 0, 0.92);
            overflow-y: auto;
        }

        .viewer-overlay.d-none {
            display: none;
        }

        .viewer-content {
            max-width: 900px;
            margin: 2rem auto;
            padding: 0 1rem 2rem;
            color: #fff;
            position: relative;
        }

        .viewer-content img {
            max-width: 100%;
            max-height: 70vh;
            display: block;
            margin: 0 auto 1.5rem;
        }

        .viewer-close {
            position: sticky;
            top: 1rem;
            float: right;
            background: none;
            border: none;
            color: #fff;
            font-size: 2rem;
            line-height: 1;
            cursor: pointer;
        }
    </style>
</head>

<body>
    <div class="container mb-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Manage Pictures</h1>
            <a href="/logout" class="btn btn-outline-secondary">Logout</a>
        </div>

        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <label for="tagFilter" class="me-2">Filter by tag:</label>
            <select id="tagFilter" class="form-select w-auto">
                <option value="">All tags</option>
            </select>
        </div>

        <div id="galleryStatus" class="mb-3"></div>

        <div id="galleryGrid" class="row row-cols-1 row-cols-md-3 g-3 mb-3"></div>

        <div class="d-flex justify-content-between align-items-center">
            <button id="prevPageBtn" class="btn btn-outline-secondary">&laquo; Previous</button>
            <span id="pageIndicator"></span>
            <button id="nextPageBtn" class="btn btn-outline-secondary">Next &raquo;</button>
        </div>
    </div>

    <div id="viewerOverlay" class="viewer-overlay d-none">
        <div class="viewer-content">
            <button id="closeViewerBtn" class="viewer-close" aria-label="Close">&times;</button>
            <img id="viewerImage" src="" alt="">

            <p><strong>Words:</strong> <span id="viewerPhrase"></span></p>

            <div class="mb-3">
                <label for="viewerTags" class="form-label">Tags (comma separated)</label>
                <input type="text" id="viewerTags" class="form-control">
            </div>

            <div class="mb-3">
                <label for="viewerAiInstruction" class="form-label">AI phrase</label>
                <input type="text" id="viewerAiInstruction" class="form-control">
            </div>

            <div class="mb-3">
                <label for="viewerOriginalPhrase" class="form-label">Link to original (three-word phrase)</label>
                <input type="text" id="viewerOriginalPhrase" class="form-control">
                <a id="viewerOriginalLink" href="#" target="_blank" rel="noopener" class="d-none">Open original</a>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4">
                <button id="deleteBtn" class="btn btn-danger">Delete</button>
                <button id="saveBtn" class="btn btn-primary">Save</button>
            </div>

            <p id="viewerStatus" class="mt-3"></p>
        </div>
    </div>

    <script src="/public/manage.js"></script>
</body>

</html>
